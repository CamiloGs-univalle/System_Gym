# Copiar a .env y ajustar según el entorno.

# Opción A (recomendada en desarrollo): usar el proxy de Vite.
# vite.config.js ya redirige /api -> http://localhost:8080
VITE_API_URL=/api

# Opción B: apuntar directo al backend (requiere CORS habilitado en Quarkus,
# ver backend/application.properties.cors-snippet.txt)
# VITE_API_URL=http://localhost:8080/api

VITE_APP_NAME=GymCore
VITE_APP_MODE=web
